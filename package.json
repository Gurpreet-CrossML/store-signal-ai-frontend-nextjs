{
  "name": "store-signals-ai-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --env-file-if-exists=.env node_modules/.bin/vitest run",
    "test:watch": "node --env-file-if-exists=.env node_modules/.bin/vitest",
    "fetch-rds-ca": "curl -fsSL https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem -o global-bundle.pem",
    "postinstall": "npm run fetch-rds-ca",
    "db:sync": "node --env-file-if-exists=.env --import tsx scripts/db-sync.ts",
    "db:check": "node --env-file-if-exists=.env --import tsx scripts/db-check.ts",
    "db:inspect": "node --env-file-if-exists=.env --import tsx scripts/inspect-schemas.ts",
    "db:smoke": "node --env-file-if-exists=.env --import tsx scripts/smoke-tenant.ts"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-react": "^11.1.2",
    "@reduxjs/toolkit": "^2.12.0",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.16.1",
    "ckeditor5": "^48.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "formik": "^2.4.9",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
